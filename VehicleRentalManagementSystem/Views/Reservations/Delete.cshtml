@model VehicleRentalManagementSystem.Models.Reservation

@{
    ViewData["Title"] = "Delete Reservation";
}

<h1>Delete Reservation</h1>
<h3>Are you sure you want to delete this?</h3>

<div>
    <p><strong>@Model.Customer?.FullName</strong></p>
    <p>@Model.Vehicle?.Make @Model.Vehicle?.Model</p>
    <p>@Model.StartDate.ToShortDateString() - @Model.EndDate.ToShortDateString()</p>
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>